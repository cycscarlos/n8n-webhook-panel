      "credentials": {
        "googleDriveOAuth2Api": {
          "id": "XXfqb1Ajzkr6Ayzk",
          "name": "Google Drive account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst allFiles = [];\nfor (const item of items) {\n  const files = item.json.files || [];\n  allFiles.push(...files);\n}\nconsole.log(`Total archivos activos encontrados: ${allFiles.length}`);\nif (allFiles.length === 0) return [];\nreturn allFiles.map(f => ({ json: { fileId: f.id, fileName: f.name } }));\n"
      },
      "name": "Extraer Activos",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [500, -120],
      "id": "extract-active-001"
    },
    {
