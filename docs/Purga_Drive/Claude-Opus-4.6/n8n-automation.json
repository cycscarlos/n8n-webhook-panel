        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "pageSize", "value": "1000" },
            { "name": "fields", "value": "nextPageToken, files(id, name)" },
            { "name": "q", "value": "trashed = false" }
          ]
        },
        "options": {
          "pagination": {
            "pagination": {
              "paginationMode": "updateAParameterInEachRequest",
              "parameters": {
                "parameters": [
                  {
                    "name": "pageToken",
                    "value": "={{ $response.body.nextPageToken }}"
                  }
                ]
              },
              "paginationCompleteWhen": "other",
              "completeExpression": "={{ !$response.body.nextPageToken }}",
              "limitPagesFetched": false,
              "maxRequests": 200
            }
          }
        }
      },
      "name": "Listar TODOS Activos",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [260, -120],
